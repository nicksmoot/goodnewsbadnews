# Copy to .env for local dev, or set these in Vercel → Settings → Environment Variables.

# --- Database (Vercel Postgres integration adds these automatically) ---
# Pooled connection (app queries) and direct connection (migrations).
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# --- Auth.js ---
# Generate one: `openssl rand -base64 33`  (or `npx auth secret`)
AUTH_SECRET=

# Only needed for non-Vercel hosting; on Vercel this is auto-detected.
# AUTH_TRUST_HOST=true
