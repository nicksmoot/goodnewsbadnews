# Copy to .env for local dev, or set these in Vercel → Settings → Environment Variables.

# --- Database (Neon via the Vercel integration adds these automatically) ---
# Pooled connection (app queries) and direct/unpooled connection (migrations).
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# --- Auth.js ---
# Generate one: `openssl rand -base64 33`  (or `npx auth secret`)
AUTH_SECRET=

# Only needed for non-Vercel hosting; on Vercel this is auto-detected.
# AUTH_TRUST_HOST=true

# --- Stripe (see docs/STRIPE-SETUP.md) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MEMBERSHIP=
# Only needed if you flip paidModel on ($0.50 per post):
STRIPE_PRICE_SUBMISSION=

# Canonical site URL (share images, SEO, Stripe redirects)
NEXT_PUBLIC_SITE_URL=

# --- Email / Saturday Digest (see docs/EMAIL-SETUP.md) ---
# Leave RESEND_API_KEY unset and the digest pipeline no-ops safely.
RESEND_API_KEY=
# Verified sender once your domain is set up in Resend:
DIGEST_FROM="Good News Bad News <digest@gnbnmedia.com>"
# Secret that authorizes the weekly Vercel Cron send (any long random string):
CRON_SECRET=
# Where newsroom partner inquiries are emailed (your inbox). Unset = no notify.
PARTNER_INBOX=
